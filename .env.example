DRAMAHUB_WEB_BASE=https://dramahub.me
DRAMAHUB_APP_BASE=https://api.dramatv.app
DRAMAHUB_CDN_BASE=https://ccdn.dramahub.me

# Optional. Prefer passing Authorization from your app per request.
# DRAMAHUB_BEARER_TOKEN=

# Root compatibility routes (/api/..., /auth/..., /payment/...) can target:
# web = dramahub.me, app = api.dramatv.app
DRAMAHUB_DEFAULT_UPSTREAM=web
DRAMAHUB_DEFAULT_LANGUAGE=hi
# Fallback only. Real apps should call /client/auth/device and use its bearer token.
DRAMAHUB_DEVICE_ID=dramahub-wrapper-local

# Used to HMAC-sign wrapper bearer tokens returned by /client/auth/device.
# Set this to a stable, private value in production.
DRAMAHUB_WRAPPER_TOKEN_SECRET=change-me-in-production

# Comma-separated origins, or * for all local/dev clients.
DRAMAHUB_CORS_ORIGINS=*

# Firestore/Firebase persistence. Leave disabled for local memory-only runs.
FIRESTORE_ENABLED=false
# FIREBASE_PROJECT_ID=your-firebase-project-id
# GOOGLE_APPLICATION_CREDENTIALS=C:\secure\firebase-service-account.json
# FIRESTORE_DATABASE=(default)
FIRESTORE_COLLECTION_PREFIX=dramaverse
